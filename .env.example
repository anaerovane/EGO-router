# Copy this file to .env and fill in the values before running real experiments.

# Required for real LLM / judge mode
OPENAI_API_KEY=your_api_key_here

# Optional: override the default OpenAI-compatible base URL and models
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4.1-mini
OPENAI_JUDGE_MODEL=gpt-4.1-mini
